#!/usr/bin/env python3
"""Visual theme picker for hypr-rice.

A floating GTK4 grid of theme cards -- wallpaper preview, name, and accent
palette swatches -- styled with the ACTIVE theme's colors. Click a card (or
use arrows + Enter, or keys 1-9) to apply that theme through the same
locked pipeline the CLI uses. Esc closes. An extra card re-extracts colors
from the current wallpaper ("auto" mode).
"""
import json
import re
import subprocess
import sys
from pathlib import Path

import gi
gi.require_version("Gtk", "4.0")
from gi.repository import Gtk, Gdk, GLib  # noqa: E402

HOME = Path.home()
BLUEPRINTS = HOME / ".config/aether/blueprints"
STATE = HOME / ".config/aether/current-theme"
COLLECTIONS = HOME / "Pictures/wallpapers/collections"

ICONS = {
    "elden-ring": "\U000f0787",
    "ashen-flame": "\U000f0238",
    "god-of-war": "\U000f08c8",
    "fallout": "\U000f043c",
    "cyberpunk-2077": "\U000f068c",
    "tokyo-night": "\U000f11a1",
    "gruvbox": "\U000f0176",
    "catppuccin-mocha": "\U000f011b",
}

current = STATE.read_text().strip() if STATE.exists() else ""

# active theme's palette for styling the picker itself
toml = (HOME / ".config/aether/theme/colors.toml").read_text()
pal = {m.group(1): m.group(2) for m in re.finditer(r'^(\w+)\s*=\s*"([^"]*)"', toml, re.M)}
BG = pal.get("background", "#111")
FG = pal.get("foreground", "#ddd")
ACCENT = pal.get("accent", "#d4a017")
MUTED = pal.get("muted", "#555")


def load_themes():
    themes = []
    for f in sorted(BLUEPRINTS.glob("*.json")):
        try:
            bp = json.loads(f.read_text())
        except Exception:
            continue
        name = bp.get("name", f.stem)
        wall = bp.get("palette", {}).get("wallpaper", "")
        colors = bp.get("palette", {}).get("colors", [])[:8]
        accent = bp.get("palette", {}).get("extendedColors", {}).get("accent", "#888")
        themes.append({"name": name, "wallpaper": wall, "colors": colors, "accent": accent})
    return themes


def apply_theme(name):
    if name == "__auto__":
        wall = (HOME / "Pictures/wallpapers/wall.png").resolve()
        cmd = f'exec 9>/tmp/aether-apply.lock; flock -w 60 9 || exit 1; aether --generate "{wall}"'
    else:
        cmd = (f'exec 9>/tmp/aether-apply.lock; flock -w 60 9 || exit 1; '
               f"printf '%s' \"{name}\" > \"$HOME/.config/aether/current-theme\"; "
               f'aether --apply-blueprint "{name}"')
    subprocess.Popen(["setsid", "bash", "-c", cmd],
                     stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)


CSS = f"""
window {{
    background: alpha({BG}, 0.88);
}}
.title {{
    color: {FG};
    font-family: "JetBrainsMono Nerd Font";
    font-size: 20px;
    font-weight: 800;
    letter-spacing: 6px;
}}
.subtitle {{
    color: alpha({FG}, 0.45);
    font-family: "JetBrainsMono Nerd Font";
    font-size: 11px;
}}
button.card {{
    background: alpha({FG}, 0.05);
    border: 2px solid alpha({MUTED}, 0.55);
    border-radius: 16px;
    padding: 0;
    transition: all 150ms ease;
}}
button.card:hover, button.card:focus {{
    border-color: {ACCENT};
    background: alpha({ACCENT}, 0.12);
}}
button.card.current {{
    border-color: {ACCENT};
    box-shadow: 0 0 14px alpha({ACCENT}, 0.45);
}}
.thumbframe {{
    border-radius: 12px;
}}
.cardname {{
    color: {FG};
    font-family: "JetBrainsMono Nerd Font";
    font-size: 13px;
    font-weight: 700;
}}
.cardicon {{
    color: {ACCENT};
    font-family: "JetBrainsMono Nerd Font";
    font-size: 15px;
}}
.currenttag {{
    color: {ACCENT};
    font-family: "JetBrainsMono Nerd Font";
    font-size: 10px;
}}
.swatch {{
    border-radius: 4px;
}}
"""


class Picker(Gtk.Application):
    def __init__(self):
        super().__init__(application_id="rice.themepicker")

    def do_activate(self):
        win = Gtk.ApplicationWindow(application=self, title="Theme Picker")
        win.set_default_size(1060, 640)

        prov = Gtk.CssProvider()
        prov.load_from_data(CSS.encode())
        Gtk.StyleContext.add_provider_for_display(
            Gdk.Display.get_default(), prov,
            Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION)

        root = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=8,
                       margin_top=26, margin_bottom=22, margin_start=30, margin_end=30)

        title = Gtk.Label(label="SELECT  THEME")
        title.add_css_class("title")
        root.append(title)
        sub = Gtk.Label(label="click / arrows + enter / 1-9   ·   esc to close")
        sub.add_css_class("subtitle")
        sub.set_margin_bottom(10)
        root.append(sub)

        grid = Gtk.FlowBox(max_children_per_line=3, min_children_per_line=3,
                           selection_mode=Gtk.SelectionMode.NONE,
                           row_spacing=14, column_spacing=14,
                           homogeneous=True)

        themes = load_themes()
        themes.append({"name": "__auto__", "wallpaper": str(HOME / "Pictures/wallpapers/wall.png"),
                       "colors": [], "accent": ACCENT})

        for i, t in enumerate(themes):
            grid.append(self.make_card(t, i))

        root.append(grid)
        win.set_child(root)

        keys = Gtk.EventControllerKey()
        keys.connect("key-pressed", self.on_key, themes)
        win.add_controller(keys)

        win.present()

    def make_card(self, t, index):
        name = t["name"]
        is_auto = name == "__auto__"
        shown = "auto (from wallpaper)" if is_auto else name

        btn = Gtk.Button()
        btn.add_css_class("card")
        if name == current:
            btn.add_css_class("current")

        v = Gtk.Box(orientation=Gtk.Orientation.VERTICAL, spacing=6,
                    margin_top=8, margin_bottom=10, margin_start=8, margin_end=8)

        wall = t["wallpaper"]
        pic = Gtk.Picture()
        pic.set_size_request(300, 150)
        pic.add_css_class("thumbframe")
        pic.set_content_fit(Gtk.ContentFit.COVER)
        if wall and Path(wall).exists():
            pic.set_filename(wall)
        v.append(pic)

        row = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=8)
        row.set_halign(Gtk.Align.CENTER)
        icon = Gtk.Label(label="\U000f02e9" if is_auto else ICONS.get(name, "\U000f03d8"))
        icon.add_css_class("cardicon")
        row.append(icon)
        lab = Gtk.Label(label=shown)
        lab.add_css_class("cardname")
        row.append(lab)
        if name == current:
            cur = Gtk.Label(label="● active")
            cur.add_css_class("currenttag")
            row.append(cur)
        v.append(row)

        if t["colors"]:
            sw = Gtk.Box(orientation=Gtk.Orientation.HORIZONTAL, spacing=4)
            sw.set_halign(Gtk.Align.CENTER)
            for c in t["colors"]:
                d = Gtk.Box()
                d.set_size_request(18, 6)
                d.add_css_class("swatch")
                p = Gtk.CssProvider()
                p.load_from_data(f".swatch-{index}-{c.lstrip('#')} {{ background: {c}; }}".encode())
                d.add_css_class(f"swatch-{index}-{c.lstrip('#')}")
                Gtk.StyleContext.add_provider_for_display(
                    Gdk.Display.get_default(), p,
                    Gtk.STYLE_PROVIDER_PRIORITY_APPLICATION)
                sw.append(d)
            v.append(sw)

        btn.set_child(v)
        btn.connect("clicked", lambda *_: self.choose(t["name"]))
        return btn

    def choose(self, name):
        apply_theme(name)
        self.quit()

    def on_key(self, ctrl, keyval, keycode, state, themes):
        if keyval == Gdk.KEY_Escape:
            self.quit()
            return True
        if Gdk.KEY_1 <= keyval <= Gdk.KEY_9:
            idx = keyval - Gdk.KEY_1
            if idx < len(themes):
                self.choose(themes[idx]["name"])
                return True
        return False


if len(sys.argv) > 1 and sys.argv[1] == "--apply":
    apply_theme(sys.argv[2])
    sys.exit(0)

Picker().run(None)
