#!/usr/bin/env python3
"""Generate a per-theme cursor set recolored from the Breeze cursor sources.

For the active Aether theme, recolors Breeze's open-source SVG cursor shapes
(two-tone: dark fill derived from the theme accent + light outline) and
builds proper multi-size Xcursor files (24/32/48) so cursors render at the
configured size instead of the source bitmap size.

A personal override PNG at
~/.local/share/hypr-rice-personal/cursor-overrides/<theme>/default.png
replaces the arrow/pointer shape for that theme (e.g. a custom downloaded
cursor kept out of the public repo).

The result is cached per theme at ~/.local/share/icons/Aether-Cursor-<theme>
and exposed under the STABLE name "Aether-Cursor" via a symlink, so
XCURSOR_THEME / settings.ini never need to change per theme -- switching
just swaps the symlink and pokes the compositor.
"""
import colorsys
import json
import os
import re
import subprocess
import tempfile
from pathlib import Path

HOME = Path.home()
SRC = Path("/usr/share/icons/breeze_cursors/cursors_scalable")
ICONS = HOME / ".local/share/icons"
OVERRIDES = HOME / ".local/share/hypr-rice-personal/cursor-overrides"
SIZES = (24, 32, 48)

import sys

# --build <theme>: build that theme's set (accent read from its blueprint)
# without activating it -- used to pre-generate all themes at install time.
BUILD_ONLY = len(sys.argv) > 2 and sys.argv[1] == "--build"

if BUILD_ONLY:
    theme = sys.argv[2]
    bp_file = HOME / ".config/aether/blueprints" / f"{theme}.json"
    accent = "d4a017"
    if bp_file.exists():
        bp = json.loads(bp_file.read_text())
        accent = bp.get("palette", {}).get("extendedColors", {}).get(
            "accent", "#d4a017").lstrip("#")
else:
    state = HOME / ".config/aether/current-theme"
    theme = state.read_text().strip() if state.exists() else "default"
    toml = (HOME / ".config/aether/theme/colors.toml").read_text()
    m = re.search(r'^accent\s*=\s*"#([0-9a-fA-F]{6})"', toml, re.M)
    accent = m.group(1) if m else "d4a017"

# Hand-tuned palettes where the auto-derivation isn't ideal; everything else
# derives fill/outline from the accent hue.
FIXED = {
    "elden-ring": ("#61553d", "#a59879"),   # sampled from the custom arrow
    "ashen-flame": ("#61553d", "#a59879"),
}


def derive(accent_hex):
    r, g, b = (int(accent_hex[i:i + 2], 16) / 255 for i in (0, 2, 4))
    h, l, s = colorsys.rgb_to_hls(r, g, b)
    def hx(hh, ll, ss):
        rr, gg, bb = colorsys.hls_to_rgb(hh, ll, ss)
        return f"#{int(rr*255):02x}{int(gg*255):02x}{int(bb*255):02x}"
    return hx(h, 0.28, min(1, s * 0.6)), hx(h, 0.62, min(1, s * 0.45))


FILL, OUTLINE = FIXED.get(theme, derive(accent))

name = f"Aether-Cursor-{theme}"
out = ICONS / name
cursors = out / "cursors"


def recolor_svg(svg_text):
    svg_text = re.sub(r'fill="#fff(?:fff)?"', f'fill="{OUTLINE}"', svg_text, flags=re.I)
    for hexcol in ("#333", "#46a7ac", "#d4497f"):  # breeze accent colors
        svg_text = svg_text.replace(f'fill="{hexcol}"', f'fill="{FILL}"')

    def repl(mt):
        tag = mt.group(0)
        if "filter=" in tag or "fill=" in tag:
            return tag
        return tag[:-2] + f' fill="{FILL}"/>'

    return re.sub(r"<path\b[^>]*/>", repl, svg_text)


if not (cursors.exists() and any(cursors.iterdir())):
    cursors.mkdir(parents=True, exist_ok=True)
    (out / "index.theme").write_text(
        "[Icon Theme]\n"
        f"Name={name}\n"
        "Comment=Theme-colored cursors generated by hypr-rice\n"
        "Inherits=breeze_cursors\n"
    )

    override_png = OVERRIDES / theme / "default.png"
    override_shapes = {"default"} if override_png.exists() else set()

    with tempfile.TemporaryDirectory() as td:
        tdp = Path(td)

        def build(name_, entries):
            """entries: list of (size, hx, hy, png_path)"""
            cfg = tdp / f"{name_}.cfg"
            cfg.write_text("".join(f"{s} {hx} {hy} {p}\n" for s, hx, hy, p in entries))
            subprocess.run(["xcursorgen", str(cfg), str(cursors / name_)],
                           capture_output=True, check=True)

        # --- personal override arrow (if any) ---
        if override_shapes:
            src_png = tdp / "ov_src.png"
            subprocess.run(["magick", str(override_png), str(src_png)], check=True)
            native = 32  # override PNGs are 32x32 with hotspot 0,0
            entries = []
            for s in SIZES:
                p = tdp / f"ov_{s}.png"
                subprocess.run(["magick", str(src_png), "-resize", f"{s}x{s}", str(p)],
                               capture_output=True, check=True)
                entries.append((s, 0, 0, p))
            build("default", entries)

        # --- recolored breeze shapes ---
        built = 0
        for d in sorted(SRC.iterdir()):
            if d.is_symlink() or not d.is_dir() or not (d / "metadata.json").exists():
                continue
            shape = d.name
            if shape in override_shapes:
                continue
            meta = json.loads((d / "metadata.json").read_text())
            frame = meta[0]  # static first frame for animated cursors
            svg_path = d / frame["filename"]
            if not svg_path.exists():
                continue
            raw = svg_path.read_text()
            nm = re.search(r'width="(\d+(?:\.\d+)?)"', raw)
            native = float(nm.group(1)) if nm else 32.0
            recolored = recolor_svg(raw)
            hx0, hy0 = frame["hotspot_x"], frame["hotspot_y"]

            entries = []
            for s in SIZES:
                p = tdp / f"{shape}_{s}.png"
                with open(p, "wb") as f:
                    subprocess.run(["rsvg-convert", "-w", str(s), "-h", str(s)],
                                   input=recolored.encode(), stdout=f, check=True)
                scale = s / native
                entries.append((s, round(hx0 * scale), round(hy0 * scale), p))
            build(shape, entries)
            built += 1

        # --- aliases (breeze's symlink structure) ---
        for d in sorted(SRC.iterdir()):
            if not d.is_symlink():
                continue
            target = os.readlink(d)
            alias = cursors / d.name
            if (cursors / target).exists() and not alias.exists() and not alias.is_symlink():
                alias.symlink_to(target)

        # default falls back to breeze's own name mapping when no override:
        if not override_shapes and not (cursors / "default").exists():
            pass  # breeze scalable set includes 'default' as a real shape

    print(f"{name}: built {built} shapes")
else:
    print(f"{name}: cached")

if BUILD_ONLY:
    sys.exit(0)

# --- activate under the stable name ---
stable = ICONS / "Aether-Cursor"
if stable.is_symlink() or stable.exists():
    if stable.is_symlink():
        stable.unlink()
subprocess.run(["ln", "-sfn", str(out), str(stable)], check=True)

# compositor: use the REAL per-theme name -- Hyprland caches theme contents
# by name, so re-pointing the Aether-Cursor symlink alone won't refresh it
subprocess.run(["hyprctl", "setcursor", name, "24"], capture_output=True)

subprocess.run(["gsettings", "set", "org.gnome.desktop.interface",
                "cursor-theme", "Aether-Cursor"], capture_output=True)
for ini in (HOME / ".config/gtk-3.0/settings.ini", HOME / ".config/gtk-4.0/settings.ini"):
    if not ini.exists():
        continue
    text = ini.read_text()
    line = "gtk-cursor-theme-name=Aether-Cursor"
    if re.search(r"^gtk-cursor-theme-name=.*$", text, re.M):
        text = re.sub(r"^gtk-cursor-theme-name=.*$", line, text, flags=re.M)
    else:
        text = text.replace("[Settings]", f"[Settings]\n{line}", 1)
    ini.write_text(text)
