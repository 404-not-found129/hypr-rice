#!/usr/bin/env python3
"""Generate a per-theme app icon set styled after the active game.

Each theme draws its own badge/frame motif (an Elden Ring rune-seal, a
Fallout Pip-Boy bezel, a Cyberpunk chamfered chip, etc.) with a gradient
plate, a soft top sheen, and a drop shadow -- rendered supersampled for
crisp anti-aliased edges. Every app's original, full-color icon sits
centered on top, at both 64px and 128px, like a real icon pack rather than
a color filter.

Installed as an icon theme ~/.local/share/icons/Aether-Game-<theme>/
(inherits Papirus-Dark for anything not covered), then activated via both
gsettings AND a direct settings.ini patch (this Hyprland setup has no
XSettings daemon, so gsettings alone never reaches running GTK apps).
Called from the Aether post-apply hook.
"""
import colorsys
import configparser
import re
import subprocess
from concurrent.futures import ThreadPoolExecutor
from pathlib import Path

HOME = Path.home()
PAPIRUS = Path("/usr/share/icons/Papirus/64x64/apps")
WORK = 512  # supersample resolution for crisp anti-aliased edges

state = HOME / ".config/aether/current-theme"
theme = state.read_text().strip() if state.exists() else "default"

toml = (HOME / ".config/aether/theme/colors.toml").read_text()
cols = {m.group(1): m.group(2) for m in re.finditer(r'^(\w+)\s*=\s*"([^"]*)"', toml, re.M)}

bg = cols.get("background", "#0e0b07")
plate = cols.get("lighter_bg", bg)
border = cols.get("accent", "#d4a017")
accent2 = cols.get("cursor", border)
muted = cols.get("muted", border)
flavor_warm = cols.get("orange") or cols.get("red") or border
flavor_pink = cols.get("magenta") or cols.get("pink") or accent2


def shade(hexcolor, factor):
    """Lighten (factor > 1) or darken (factor < 1) a hex color."""
    h = hexcolor.lstrip("#")
    r, g, b = (int(h[i:i + 2], 16) / 255 for i in (0, 2, 4))
    hue, l, s = colorsys.rgb_to_hls(r, g, b)
    l = max(0.02, min(0.98, l * factor))
    r, g, b = colorsys.hls_to_rgb(hue, l, s)
    return f"#{int(r*255):02x}{int(g*255):02x}{int(b*255):02x}"


plate_light = shade(plate, 1.5)
plate_dark = shade(plate, 0.55)

# (svg tag, attrs) for each theme's outer badge shape -- used both as the
# filled/gradient plate and as the clip mask for the sheen highlight.
SHAPES = {
    "elden-ring":       ("rect", dict(x=6, y=6, width=116, height=116, rx=18)),
    "ashen-flame":       ("rect", dict(x=6, y=6, width=116, height=116, rx=18)),
    "god-of-war":        ("rect", dict(x=6, y=6, width=116, height=116, rx=14)),
    "fallout":           ("rect", dict(x=4, y=4, width=120, height=120, rx=16)),
    "cyberpunk-2077":    ("polygon", dict(points="24,6 104,6 122,24 122,104 104,122 24,122 6,104 6,24")),
    "tokyo-night":       ("rect", dict(x=6, y=6, width=116, height=116, rx=22)),
    "gruvbox":           ("rect", dict(x=7, y=7, width=114, height=114, rx=12)),
    "catppuccin-mocha":  ("rect", dict(x=8, y=10, width=112, height=112, rx=26)),
}


def shape_tag(kind, attrs, **extra):
    a = dict(attrs)
    a.update(extra)
    attrstr = " ".join(f'{k.replace("_", "-")}="{v}"' for k, v in a.items())
    return f"<{kind} {attrstr}/>"


def decorations(theme):
    """Theme-specific flourishes drawn on top of the base plate+border."""
    if theme in ("elden-ring", "ashen-flame"):
        d = f'''
        <circle cx="64" cy="64" r="46" fill="none" stroke="{accent2}" stroke-width="2" opacity="0.55"/>
        <line x1="64" y1="9"  x2="64" y2="21"  stroke="{border}" stroke-width="3"/>
        <line x1="64" y1="107" x2="64" y2="119" stroke="{border}" stroke-width="3"/>
        <line x1="9"  y1="64" x2="21"  y2="64" stroke="{border}" stroke-width="3"/>
        <line x1="107" y1="64" x2="119" y2="64" stroke="{border}" stroke-width="3"/>'''
        if theme == "ashen-flame":
            d += f'''
        <path d="M 14 119 C 16 111 19 107 24 100 C 29 107 32 111 34 119 C 28 116 20 116 14 119 Z" fill="{border}" opacity="0.85"/>
        <path d="M 94 119 C 96 111 99 107 104 100 C 109 107 112 111 114 119 C 108 116 100 116 94 119 Z" fill="{border}" opacity="0.85"/>'''
        return d

    if theme == "god-of-war":
        return f'''
        <rect x="17" y="17" width="94" height="94" rx="8" fill="none" stroke="{muted}" stroke-width="2" opacity="0.7"/>
        <path d="M 6 6 L 32 6 L 6 32 Z" fill="{accent2}"/>
        <path d="M 122 122 L 96 122 L 122 96 Z" fill="{accent2}" opacity="0.7"/>'''

    if theme == "fallout":
        return f'''
        <rect x="18" y="18" width="92" height="92" rx="6" fill="{bg}" opacity="0.6"/>
        <line x1="18" y1="59" x2="110" y2="59" stroke="{border}" stroke-width="2" opacity="0.45"/>
        <line x1="18" y1="70" x2="110" y2="70" stroke="{border}" stroke-width="2" opacity="0.3"/>
        <circle cx="20" cy="112" r="5" fill="{border}"/>
        <circle cx="20" cy="110" r="1.6" fill="white" opacity="0.6"/>
        <circle cx="108" cy="112" r="5" fill="{border}"/>
        <circle cx="108" cy="110" r="1.6" fill="white" opacity="0.6"/>
        <circle cx="19" cy="20" r="3" fill="{accent2}"/>'''

    if theme == "cyberpunk-2077":
        return f'''
        <polygon points="34,16 94,16 112,34 112,94 94,112 34,112 16,94 16,34"
                 fill="none" stroke="{accent2}" stroke-width="1.5" opacity="0.6"/>
        <line x1="6" y1="24" x2="24" y2="6" stroke="{accent2}" stroke-width="2.5"/>
        <line x1="122" y1="104" x2="104" y2="122" stroke="{accent2}" stroke-width="2.5"/>
        <rect x="104" y="9" width="9" height="9" fill="{accent2}"/>
        <line x1="118" y1="46" x2="118" y2="54" stroke="{border}" stroke-width="2"/>
        <line x1="118" y1="60" x2="118" y2="68" stroke="{border}" stroke-width="2"/>
        <line x1="118" y1="74" x2="118" y2="82" stroke="{border}" stroke-width="2"/>'''

    if theme == "tokyo-night":
        return f'''
        <circle cx="30" cy="32" r="1.6" fill="{accent2}" opacity="0.6"/>
        <circle cx="44" cy="20" r="1.2" fill="{accent2}" opacity="0.5"/>
        <circle cx="20" cy="48" r="1.2" fill="{accent2}" opacity="0.4"/>
        <circle cx="100" cy="24" r="9" fill="{accent2}"/>
        <circle cx="106" cy="19" r="9" fill="{plate_dark}"/>
        <g opacity="0.5">
        <rect x="10" y="104" width="10" height="16" fill="{muted}"/>
        <rect x="22" y="98" width="12" height="22" fill="{muted}"/>
        <rect x="36" y="106" width="9" height="14" fill="{muted}"/>
        </g>'''

    if theme == "gruvbox":
        return f'''
        <rect x="16" y="16" width="96" height="96" rx="8" fill="none" stroke="{border}" stroke-width="1.5" opacity="0.5"/>
        <path d="M 6 6 L 24 6 L 6 24 Z" fill="{flavor_warm}" opacity="0.85"/>'''

    if theme == "catppuccin-mocha":
        return f'''
        <path d="M 26 16 L 40 16 L 30 2 Z"  fill="{plate}" stroke="{border}" stroke-width="3" stroke-linejoin="round"/>
        <path d="M 88 16 L 102 16 L 98 2 Z" fill="{plate}" stroke="{border}" stroke-width="3" stroke-linejoin="round"/>
        <path d="M 29 14 L 36 14 L 31 6 Z" fill="{flavor_pink}"/>
        <path d="M 91 14 L 98 14 L 96 6 Z" fill="{flavor_pink}"/>'''

    return ""


def badge_svg(theme):
    kind, attrs = SHAPES.get(theme, SHAPES["elden-ring"])
    fill_shape = shape_tag(kind, attrs, fill="url(#grad)")
    clip_shape = shape_tag(kind, attrs, fill="white")
    border_shape = shape_tag(kind, attrs, fill="none", stroke=border, **{"stroke-width": 4})
    return f'''<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 128 128">
<defs>
  <linearGradient id="grad" x1="0" y1="0" x2="0" y2="1">
    <stop offset="0" stop-color="{plate_light}"/>
    <stop offset="1" stop-color="{plate_dark}"/>
  </linearGradient>
  <clipPath id="clip">{clip_shape}</clipPath>
</defs>
<g clip-path="url(#clip)">
  {fill_shape}
  <ellipse cx="64" cy="26" rx="46" ry="20" fill="white" opacity="0.08"/>
</g>
{border_shape}
{decorations(theme)}
</svg>'''


name = f"Aether-Game-{theme}"
out = HOME / ".local/share/icons" / name
apps64 = out / "64x64/apps"
apps128 = out / "128x128/apps"

if not (apps64.exists() and any(apps64.iterdir())):
    apps64.mkdir(parents=True, exist_ok=True)
    apps128.mkdir(parents=True, exist_ok=True)
    (out / "index.theme").write_text(
        "[Icon Theme]\n"
        f"Name={name}\n"
        "Comment=Game-badged icons generated by hypr-rice\n"
        "Inherits=Papirus-Dark,Papirus,hicolor\n"
        "Directories=64x64/apps,128x128/apps\n\n"
        "[64x64/apps]\nSize=64\nType=Fixed\nContext=Applications\n\n"
        "[128x128/apps]\nSize=128\nType=Fixed\nContext=Applications\n"
    )

    badge = out / "badge.png"
    subprocess.run(["rsvg-convert", "-w", str(WORK), "-h", str(WORK), "-o", str(badge)],
                   input=badge_svg(theme).encode(), check=True)

    wanted = set()
    for d in (Path("/usr/share/applications"), HOME / ".local/share/applications"):
        if not d.is_dir():
            continue
        for f in d.glob("*.desktop"):
            cp = configparser.ConfigParser(interpolation=None, strict=False)
            try:
                cp.read(f, encoding="utf-8")
                icon = cp.get("Desktop Entry", "Icon", fallback="").strip()
            except Exception:
                continue
            if icon and "/" not in icon:
                wanted.add(icon)

    def find_source(icon):
        svg = PAPIRUS / f"{icon}.svg"
        if svg.exists():
            return svg
        for ctx in ("devices", "places", "mimetypes"):
            alt = PAPIRUS.parent / ctx / f"{icon}.svg"
            if alt.exists():
                return alt
        hic = Path("/usr/share/icons/hicolor")
        sc = hic / "scalable/apps" / f"{icon}.svg"
        if sc.exists():
            return sc
        pngs = sorted(hic.glob(f"*/apps/{icon}.png"),
                      key=lambda p: int(p.parts[-3].split("x")[0]) if "x" in p.parts[-3] else 0)
        if pngs:
            return pngs[-1]
        for ext in ("svg", "png"):
            pm = Path(f"/usr/share/pixmaps/{icon}.{ext}")
            if pm.exists():
                return pm
        return None

    GLYPH = round(76 / 128 * WORK)

    def render(icon):
        src = find_source(icon)
        if src is None:
            return
        try:
            if src.suffix == ".svg":
                glyph = subprocess.run(
                    ["rsvg-convert", "-w", str(GLYPH), "-h", str(GLYPH), str(src)],
                    capture_output=True, check=True).stdout
            else:
                glyph = subprocess.run(
                    ["magick", str(src), "-resize", f"{GLYPH}x{GLYPH}",
                     "-background", "none", "-gravity", "center",
                     "-extent", f"{GLYPH}x{GLYPH}", "png:-"],
                    capture_output=True, check=True).stdout
            composite = subprocess.run(
                ["magick", str(badge), "png:-", "-gravity", "center",
                 "-compose", "over", "-composite",
                 "(", "+clone", "-background", "black", "-shadow", "55x10+0+8", ")",
                 "+swap", "-background", "none", "-layers", "merge", "png:-"],
                input=glyph, capture_output=True, check=True).stdout
            subprocess.run(["magick", "png:-", "-resize", "128x128",
                            str(apps128 / f"{icon}.png")],
                           input=composite, capture_output=True, check=True)
            subprocess.run(["magick", "png:-", "-resize", "64x64",
                            str(apps64 / f"{icon}.png")],
                           input=composite, capture_output=True, check=True)
        except subprocess.CalledProcessError:
            pass

    with ThreadPoolExecutor(max_workers=12) as ex:
        list(ex.map(render, sorted(wanted)))

    subprocess.run(["gtk-update-icon-cache", "-f", "-t", str(out)], capture_output=True)

subprocess.run(["gsettings", "set", "org.gnome.desktop.interface", "icon-theme", name],
               capture_output=True)

# gsettings alone doesn't reach GTK apps here: there's no xsettingsd /
# gnome-settings-daemon on this Hyprland setup to bridge it live, so GTK
# reads gtk-icon-theme-name straight out of settings.ini at startup. Patch
# that directly or the icon theme silently never changes.
for ini in (HOME / ".config/gtk-3.0/settings.ini", HOME / ".config/gtk-4.0/settings.ini"):
    if not ini.exists():
        continue
    text = ini.read_text()
    line = f"gtk-icon-theme-name={name}"
    if re.search(r"^gtk-icon-theme-name=.*$", text, re.M):
        text = re.sub(r"^gtk-icon-theme-name=.*$", line, text, flags=re.M)
    else:
        text = text.replace("[Settings]", f"[Settings]\n{line}", 1)
    ini.write_text(text)

# walker caches icons per-process; bounce its service so it picks up the set
subprocess.run(["pkill", "-x", "walker"], capture_output=True)
subprocess.Popen(["setsid", "walker", "--gapplication-service"],
                 stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
print(f"{name}: {len(list(apps64.glob('*.png')))} icons")
