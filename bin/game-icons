#!/usr/bin/env python3
"""Generate a per-theme duotone app icon set from the game palette.

For the active Aether theme, renders every installed app's Papirus icon as a
duotone (dark shade -> accent highlight) into an icon theme
~/.local/share/icons/Aether-Game-<theme>/ (inherits Papirus-Dark), then
activates it via gsettings. Cached: generation runs once per theme.
Called from the Aether post-apply hook.
"""
import colorsys
import configparser
import re
import subprocess
import sys
from concurrent.futures import ThreadPoolExecutor
from pathlib import Path

HOME = Path.home()
PAPIRUS = Path("/usr/share/icons/Papirus/64x64/apps")

state = HOME / ".config/aether/current-theme"
theme = state.read_text().strip() if state.exists() else "default"

toml = (HOME / ".config/aether/theme/colors.toml").read_text()
def color(key):
    m = re.search(rf'^{key}\s*=\s*"#([0-9a-fA-F]{{6}})"', toml, re.M)
    return m.group(1) if m else None

accent = color("accent") or "d4a017"

# Build a monochrome ramp from the accent: deep shadow -> bright highlight
r, g, b = (int(accent[i:i + 2], 16) / 255 for i in (0, 2, 4))
h, l, s = colorsys.rgb_to_hls(r, g, b)
def hex_of(hh, ll, ss):
    rr, gg, bb = colorsys.hls_to_rgb(hh, ll, ss)
    return f"{int(rr*255):02x}{int(gg*255):02x}{int(bb*255):02x}"
dark = hex_of(h, max(0.07, l * 0.22), min(1, s * 0.9))
light = hex_of(h, min(0.72, max(0.55, l * 1.35)), s)

name = f"Aether-Game-{theme}"
out = HOME / ".local/share/icons" / name
apps = out / "64x64/apps"

if not (apps.exists() and any(apps.iterdir())):
    apps.mkdir(parents=True, exist_ok=True)
    (out / "index.theme").write_text(
        "[Icon Theme]\n"
        f"Name={name}\n"
        "Comment=Duotone game icons generated by hypr-rice\n"
        "Inherits=Papirus-Dark,Papirus,hicolor\n"
        "Directories=64x64/apps\n\n"
        "[64x64/apps]\nSize=64\nType=Fixed\nContext=Applications\n"
    )

    # icon names of every installed app
    wanted = set()
    for d in (Path("/usr/share/applications"), HOME / ".local/share/applications"):
        if not d.is_dir():
            continue
        for f in d.glob("*.desktop"):
            cp = configparser.ConfigParser(interpolation=None, strict=False)
            try:
                cp.read(f, encoding="utf-8")
                icon = cp.get("Desktop Entry", "Icon", fallback="").strip()
            except Exception:
                continue
            if icon and "/" not in icon:
                wanted.add(icon)

    def find_source(icon):
        svg = PAPIRUS / f"{icon}.svg"
        if svg.exists():
            return svg
        # some .desktop files use device/place icons (e.g. network-wired)
        for ctx in ("devices", "places", "mimetypes"):
            alt = PAPIRUS.parent / ctx / f"{icon}.svg"
            if alt.exists():
                return alt
        hic = Path("/usr/share/icons/hicolor")
        sc = hic / "scalable/apps" / f"{icon}.svg"
        if sc.exists():
            return sc
        pngs = sorted(hic.glob(f"*/apps/{icon}.png"),
                      key=lambda p: int(p.parts[-3].split("x")[0]) if "x" in p.parts[-3] else 0)
        if pngs:
            return pngs[-1]
        for ext in ("svg", "png"):
            pm = Path(f"/usr/share/pixmaps/{icon}.{ext}")
            if pm.exists():
                return pm
        return None

    def render(icon):
        src = find_source(icon)
        if src is None:
            return
        png = apps / f"{icon}.png"
        try:
            if src.suffix == ".svg":
                raw = subprocess.run(
                    ["rsvg-convert", "-w", "128", "-h", "128", str(src)],
                    capture_output=True, check=True).stdout
            else:
                raw = src.read_bytes()
            subprocess.run(
                ["magick", "png:-", "-resize", "64x64",
                 "-channel", "RGB", "-colorspace", "gray",
                 "(", "-size", "1x256", f"gradient:#{light}-#{dark}", "-rotate", "180", ")",
                 "-clut", "+channel", str(png)],
                input=raw, capture_output=True, check=True)
        except subprocess.CalledProcessError:
            pass

    with ThreadPoolExecutor(max_workers=12) as ex:
        list(ex.map(render, sorted(wanted)))

    subprocess.run(["gtk-update-icon-cache", "-f", "-t", str(out)],
                   capture_output=True)

subprocess.run(["gsettings", "set", "org.gnome.desktop.interface",
                "icon-theme", name], capture_output=True)

# gsettings alone doesn't reach GTK apps here: there's no xsettingsd /
# gnome-settings-daemon on this Hyprland setup to bridge it live, so GTK
# reads gtk-icon-theme-name straight out of settings.ini at startup. Patch
# that directly or the icon theme silently never changes.
for ini in (HOME / ".config/gtk-3.0/settings.ini", HOME / ".config/gtk-4.0/settings.ini"):
    if not ini.exists():
        continue
    text = ini.read_text()
    line = f"gtk-icon-theme-name={name}"
    if re.search(r"^gtk-icon-theme-name=.*$", text, re.M):
        text = re.sub(r"^gtk-icon-theme-name=.*$", line, text, flags=re.M)
    else:
        text = text.replace("[Settings]", f"[Settings]\n{line}", 1)
    ini.write_text(text)

# walker caches icons per-process; bounce its service so it picks up the set
subprocess.run(["pkill", "-x", "walker"], capture_output=True)
subprocess.Popen(["setsid", "walker", "--gapplication-service"],
                 stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
print(f"{name}: {len(list(apps.glob('*.png')))} icons")
