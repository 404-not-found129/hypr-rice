#!/usr/bin/env python3
"""Generate a GTK filter that tints walker's app icons toward the theme
accent (monochrome-tint look). Writes walker themes/aether/icons.css.
Called from the Aether post-apply hook."""
import colorsys
import re
from pathlib import Path

toml = Path.home() / ".config/aether/theme/colors.toml"
out = Path.home() / ".config/walker/themes/aether/icons.css"

m = re.search(r'^accent\s*=\s*"#([0-9a-fA-F]{6})"', toml.read_text(), re.M)
if not m:
    raise SystemExit(0)

r, g, b = (int(m.group(1)[i:i + 2], 16) / 255 for i in (0, 2, 4))
h, l, s = colorsys.rgb_to_hls(r, g, b)

if s < 0.12:  # gray accent -> plain monochrome icons
    flt = "grayscale(1) brightness(1.15)"
else:
    # sepia() lands around hue ~40deg; rotate from there to the accent hue
    rot = int(round(h * 360 - 40))
    sat = 2.2 if s > 0.5 else 1.5
    flt = f"grayscale(1) sepia(1) hue-rotate({rot}deg) saturate({sat}) brightness(1.05)"

out.parent.mkdir(parents=True, exist_ok=True)
out.write_text(
    "/* generated by icon-tint — app icons tinted to the theme accent */\n"
    f".normal-icons,\n.large-icons,\n.item-image {{ filter: {flt}; }}\n"
)
print(flt)
