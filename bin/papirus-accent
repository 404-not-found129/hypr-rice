#!/usr/bin/env python3
"""Map the current Aether accent color to the nearest Papirus folder color
and apply it with papirus-folders. Called from Aether's post-apply hook."""
import colorsys
import re
import subprocess
import sys
from pathlib import Path

toml = Path.home() / ".config/aether/theme/colors.toml"
m = re.search(r'^accent\s*=\s*"#([0-9a-fA-F]{6})"', toml.read_text(), re.M)
if not m:
    sys.exit(0)

r, g, b = (int(m.group(1)[i:i + 2], 16) / 255 for i in (0, 2, 4))
h, l, s = colorsys.rgb_to_hls(r, g, b)
hue = h * 360

if s < 0.12:
    color = "grey"
else:
    # papirus color -> anchor hue
    anchors = {
        "red": 0, "deeporange": 16, "orange": 30, "yellow": 48,
        "green": 120, "teal": 165, "cyan": 190, "blue": 220,
        "indigo": 250, "violet": 275, "magenta": 305, "pink": 335,
        "carmine": 355,
    }
    color = min(anchors, key=lambda c: min(abs(hue - anchors[c]), 360 - abs(hue - anchors[c])))

subprocess.run(
    ["papirus-folders", "-C", color, "--theme", "Papirus-Dark"],
    check=False, capture_output=True,
)
print(color)
